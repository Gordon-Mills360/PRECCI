# FILE: precci/.env.example
# ═══════════════════════════════════════════════════════════════
# PRECCI — COMPLETE ENVIRONMENT VARIABLES TEMPLATE
# ALL 4 PHASES — EVERY VARIABLE LISTED
# Gordon fills these in privately. Never share this file with values.
# Copy this file to .env and fill in real values before running.
# ═══════════════════════════════════════════════════════════════

# ── SUPABASE ─────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Found in: Supabase Dashboard → Project Settings → API

# ── ANTHROPIC (Claude API + Claude Vision) ────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-sonnet-4-6
# Found in: https://console.anthropic.com → API Keys

# ── ELEVENLABS (All 28 Agent Voice IDs) ──────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Agent voice IDs — assign a unique ElevenLabs voice to each agent
ELEVENLABS_VOICE_JARVIS=voice_id_for_jarvis
ELEVENLABS_VOICE_VIVIENNE=voice_id_for_vivienne
ELEVENLABS_VOICE_CELESTE=voice_id_for_celeste
ELEVENLABS_VOICE_MARCUS=voice_id_for_marcus
ELEVENLABS_VOICE_SIENNA=voice_id_for_sienna
ELEVENLABS_VOICE_RAFAEL=voice_id_for_rafael
ELEVENLABS_VOICE_NADIA=voice_id_for_nadia
ELEVENLABS_VOICE_SEBASTIAN=voice_id_for_sebastian
ELEVENLABS_VOICE_GRACE=voice_id_for_grace
ELEVENLABS_VOICE_LUNA=voice_id_for_luna
ELEVENLABS_VOICE_ZARA=voice_id_for_zara
ELEVENLABS_VOICE_MIA=voice_id_for_mia
ELEVENLABS_VOICE_ISLA=voice_id_for_isla
ELEVENLABS_VOICE_REMY=voice_id_for_remy
ELEVENLABS_VOICE_CORA=voice_id_for_cora
ELEVENLABS_VOICE_DREW=voice_id_for_drew
ELEVENLABS_VOICE_SAGE=voice_id_for_sage
ELEVENLABS_VOICE_BELLE=voice_id_for_belle
ELEVENLABS_VOICE_NOVA=voice_id_for_nova
ELEVENLABS_VOICE_PIPER=voice_id_for_piper
ELEVENLABS_VOICE_NINA=voice_id_for_nina
ELEVENLABS_VOICE_ELTON=voice_id_for_elton
ELEVENLABS_VOICE_LENA=voice_id_for_lena
ELEVENLABS_VOICE_FINN=voice_id_for_finn
ELEVENLABS_VOICE_AURORA=voice_id_for_aurora
ELEVENLABS_VOICE_COLE=voice_id_for_cole
ELEVENLABS_VOICE_EVA=voice_id_for_eva
ELEVENLABS_VOICE_BROOK=voice_id_for_brook
# Found in: https://elevenlabs.io → Voices → copy Voice ID

# ── OPENAI (Whisper for JARVIS) ───────────────────────────────
OPENAI_API_KEY=your_openai_api_key
OPENAI_WHISPER_MODEL=whisper-1
# Found in: https://platform.openai.com → API Keys

# ── VAPI (Client + Provider Voice Agents) ────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret
# Grace — always-on client greeting agent
VAPI_ASSISTANT_ID_GRACE=vapi_assistant_id_for_grace
# Specialist agents — activated by Grace routing
VAPI_ASSISTANT_ID_LUNA=vapi_assistant_id_for_luna
VAPI_ASSISTANT_ID_ZARA=vapi_assistant_id_for_zara
VAPI_ASSISTANT_ID_MIA=vapi_assistant_id_for_mia
VAPI_ASSISTANT_ID_ISLA=vapi_assistant_id_for_isla
VAPI_ASSISTANT_ID_REMY=vapi_assistant_id_for_remy
VAPI_ASSISTANT_ID_CORA=vapi_assistant_id_for_cora
VAPI_ASSISTANT_ID_DREW=vapi_assistant_id_for_drew
VAPI_ASSISTANT_ID_BELLE=vapi_assistant_id_for_belle
VAPI_ASSISTANT_ID_NOVA=vapi_assistant_id_for_nova
VAPI_ASSISTANT_ID_PIPER=vapi_assistant_id_for_piper
VAPI_ASSISTANT_ID_LENA=vapi_assistant_id_for_lena
VAPI_ASSISTANT_ID_AURORA=vapi_assistant_id_for_aurora
VAPI_ASSISTANT_ID_BROOK=vapi_assistant_id_for_brook
# Provider voice agents — one per registered provider (dynamic, stored in Supabase)
VAPI_PROVIDER_AGENT_TEMPLATE_ID=vapi_template_id_for_provider_agents
# Found in: https://vapi.ai → Dashboard → Assistants

# ── REPLICATE (Belle Virtual Try-On — All Genders) ───────────
REPLICATE_API_TOKEN=your_replicate_api_token
REPLICATE_MODEL_TRYON=stability-ai/sdxl:model_version_hash
REPLICATE_MODEL_CONTROLNET=lllyasviel/control_v11p_sd15_openpose:version_hash
# Found in: https://replicate.com → Account → API Tokens

# ── OPENWEATHERMAP (Sage Environmental Intelligence) ─────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
# Found in: https://openweathermap.org → My API Keys

# ── GOOGLE MAPS (Brook Proximity Search) ─────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Enable: Maps JavaScript API, Places API, Geocoding API, Distance Matrix API
# Found in: https://console.cloud.google.com → APIs & Services → Credentials

# ── RESEND (Email — Clients and Providers) ────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=hello@precci.com
RESEND_FROM_NAME=PRECCI
# Found in: https://resend.com → API Keys

# ── TWILIO (SMS — Clients and Providers) ─────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
# Found in: https://console.twilio.com → Account Info

# ── PAYSTACK (Africa — Mobile Money + Cards) ─────────────────
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret
# Found in: https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Webhook URL to set: https://your-render-url.onrender.com/api/webhooks/paystack

# ── STRIPE (Global Payments) ─────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
# Stripe Product/Price IDs — create these in Stripe Dashboard
STRIPE_PRICE_GLOW=price_id_for_glow_9_99
STRIPE_PRICE_PRO=price_id_for_pro_19_99
STRIPE_PRICE_ELITE=price_id_for_elite_29_99
STRIPE_PRICE_PROVIDER_BASIC=price_id_for_provider_basic_15
STRIPE_PRICE_PROVIDER_PRO=price_id_for_provider_pro_30
# Found in: https://dashboard.stripe.com → Developers → API Keys
# Webhook URL to set: https://your-render-url.onrender.com/api/webhooks/stripe

# ── META API (Nina — Instagram + Facebook) ───────────────────
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_access_token
META_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
META_PAGE_ID=your_facebook_page_id
# Found in: https://developers.facebook.com → Your App

# ── TIKTOK API (Nina) ─────────────────────────────────────────
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token
# Found in: https://developers.tiktok.com → My Apps

# ── PINTEREST API (Nina) ─────────────────────────────────────
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_ACCESS_TOKEN=your_pinterest_access_token
# Found in: https://developers.pinterest.com → My Apps

# ── MODASH (Nina — Influencer Search) ────────────────────────
MODASH_API_KEY=your_modash_api_key
# Found in: https://app.modash.io → Settings → API

# ── META ADS API (Finn) ──────────────────────────────────────
META_ADS_ACCESS_TOKEN=your_meta_ads_access_token
META_ADS_ACCOUNT_ID=your_meta_ads_account_id
# Found in: https://business.facebook.com → Ads Manager

# ── GOOGLE ADS API (Finn) ────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=your_google_ads_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_ads_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_google_ads_refresh_token
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CUSTOMER_ID=your_google_ads_customer_id
# Found in: https://ads.google.com → Tools → API Center

# ── SERPER API (Nova / Cole / Elton) ─────────────────────────
SERPER_API_KEY=your_serper_api_key
# Found in: https://serper.dev → Dashboard → API Key

# ── TEACHABLE (Piper — Beauty Academy) ───────────────────────
TEACHABLE_API_KEY=your_teachable_api_key
TEACHABLE_SCHOOL_SUBDOMAIN=your_teachable_school_name
# Found in: https://teachable.com → Settings → Integrations → API

# ── CIRCLE.SO (Aurora — Inner Circle Community) ──────────────
CIRCLESO_API_KEY=your_circleso_api_key
CIRCLESO_COMMUNITY_ID=your_circleso_community_id
# Found in: https://app.circle.so → Settings → API

# ── SENTRY (Error Monitoring) ────────────────────────────────
SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=precci-backend
# Found in: https://sentry.io → Settings → Projects → Client Keys (DSN)

# ── APP CONFIGURATION ────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://precci.com
API_URL=https://api.precci.com
DASHBOARD_URL=https://dashboard.precci.com
PROVIDER_PORTAL_URL=https://precci.com/connect
JWT_SECRET=your_jwt_secret_minimum_64_characters_random_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_minimum_64_characters_random_string
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ── PRECCI CONNECT CONFIGURATION ─────────────────────────────
# Registration fee
CONNECT_REGISTRATION_FEE_USD=25

# Monthly subscription tier prices (USD)
CONNECT_SUBSCRIPTION_BASIC_USD=15
CONNECT_SUBSCRIPTION_PRO_USD=30

# Featured placement add-on prices (USD range)
CONNECT_FEATURED_MIN_USD=20
CONNECT_FEATURED_MAX_USD=50

# Per-booking referral fees (USD)
CONNECT_REFERRAL_FEE_BASIC=3.00
CONNECT_REFERRAL_FEE_PRO=2.00
CONNECT_REFERRAL_FEE_FEATURED=1.50

# Appointment code expiry (hours after appointment time)
CONNECT_APPOINTMENT_CODE_EXPIRY_HOURS=24

# Core subscription tier prices (USD)
CORE_PRICE_GLOW=9.99
CORE_PRICE_PRO=19.99
CORE_PRICE_ELITE=29.99

# Session limits for free tier
FREE_TIER_CAMERA_SESSIONS_PER_MONTH=3
GLOW_TIER_TRYON_PER_MONTH=20
